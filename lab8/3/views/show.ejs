<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        @font-face {
            font-family: Prompt;
            src: url(/font/Prompt-Regular.ttf);
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: "Prompt", sans-serif;
        }

        .box {
            display: flex;
            flex-wrap: wrap;
            align-items: stretch;
            gap: 20px;
        }

        .card {
            border: 1px solid black;
            width: 31%;
            border-radius: 5px;
            box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2);
        }

        .card img {
            width: 100%;
            height: 300px;
            object-fit: cover;
        }

        .context {
            margin: 20px;
        }

        @media screen and (max-width: 800px) {
            .card {
                width: 48%;
            }
        }

        @media screen and (max-width: 600px) {
            .card {
                width: 100%;
            }
        }

    </style>
    <title>lab8.3</title>
</head>
<body>
    <h1>The most popular albums</h1>
    <div class="box">
        <% data.forEach(music => { %>
        <div class="card">
            <img src="<%= music.album_cover %>">
            <div class="context">
                <h2><%= music.song %></h2>
                <p>Album: <%= music.album %> (<%= music.year %>)</p>
                <p>Artist: <%= music.artist %></p>
                <p>Genre: <%= music.genre %></p>
            </div>
        </div>
        <% }); %>
    </div>
    <script>

    </script>
</body>
</html>
