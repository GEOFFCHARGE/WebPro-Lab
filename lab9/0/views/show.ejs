<!doctype html>
<html lang="en">
<%- include("head") %>
<body>
    <!-- heaher -->
    <%- include("header") %>
    <!-- Content -->
    <table>
        <tr>
            <th>ID</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Title</th>
            <th>Phone</th>
            <th>Email</th>
            <th>Note</th>
        </tr>
        <% data.forEach((item)=>{ %>
        <tr>
            <td><%=item.EmployeeId%></td>
            <td><%=item.FirstName%></td>
            <td><%=item.LastName%></td>
            <td><%=item.Title%></td>
            <td><%=item.Phone%></td>
            <td><%=item.Email%></td>
            <td><a href="/delete/<%=item.EmployeeId%>">Delete</a></td>
        </tr>
        <% }); %>
    </table>
    <!-- footer -->
    <%- include("footer") %>
</body>
</html>
