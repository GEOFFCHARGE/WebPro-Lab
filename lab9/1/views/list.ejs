<!doctype html>
<html lang="en">
<%- include("head") %>
<body>
    <h1>Users List</h1>
    <table>
        <tr>
            <th>ID</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Username</th>
            <th>Email</th>
            <th>Action</th>
        </tr>
        <% data.forEach((item) => { %>
        <tr>
            <td><%= item.id %></td>
            <td><%= item.first_name %></td>
            <td><%= item.last_name %></td>
            <td><%= item.username %></td>
            <td><%= item.email %></td>
            <td><a href="/detail/<%= item.id %>" class="button">Detail</a></td>
        </tr>
        <% }); %>
    </table>
</body>
</html>
