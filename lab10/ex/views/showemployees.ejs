<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>lab10.ex</title>
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            margin: 20px;
            font-size: 24px;
        }

        img {
            border-radius: 10px 10px 0px 0px;
            width: 100%;
        }

        .card {
            border-radius: 5px;
            box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2);
            float: left;
            margin: 5px;
            padding: 15px;
            width: 30%;
            min-height: 300px;
        }

        @media screen and (max-width: 1300px) {
            .card {
                width: 45%;
                min-height: auto;
            }
        }

        @media screen and (max-width: 900px) {
            .card {
                width: 100%;
                min-height: auto;
            }
        }
    </style>
</head>
<body>
    <% data.forEach((item) => { %>
    <div class="card">
        <img src="http://webdev.it.kmitl.ac.th:4000/emp-images/<%= item.EmployeeID %>.png">
        <h3><%= item.FirstName %> <%= item.LastName %></h3>
        <a href="/showemployees/<%= item.EmployeeID %>">Details</a>
    </div>
    <% }); %>
</body>
</html>
