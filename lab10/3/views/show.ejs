<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/show.css">
    <title>lab10.3</title>
</head>
<body>
    <h1>Book Store</h1>
    <table>
        <tr>
            <th>ID</th>
            <th>Book Name</th>
            <th>Description</th>
            <th>Price</th>
            <th>Amount</th>
        </tr>
        <% data.forEach((item) => { %>
        <tr class="<%- item.id % 2 ? 'odd': 'even'; %>">
            <td><%= item.id %></td>
            <td><%= item.name %></td>
            <td><%= item.description %></td>
            <td><%= item.price %></td>
            <td><%= item.amount %></td>
        </tr>
        <% }) %>
    </table>
</body>
</html>
